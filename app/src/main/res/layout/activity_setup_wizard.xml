<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:padding="32dp">

    <!-- Spacer top -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Icon -->
    <TextView
        android:id="@+id/tvStepIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="🔒"
        android:textSize="72sp" />

    <View android:layout_width="match_parent" android:layout_height="24dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tvStepTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:gravity="center"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:textStyle="bold" />

    <View android:layout_width="match_parent" android:layout_height="16dp" />

    <!-- Body -->
    <TextView
        android:id="@+id/tvStepBody"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:textColor="@color/text_secondary"
        android:textSize="15sp" />

    <View android:layout_width="match_parent" android:layout_height="32dp" />

    <!-- Action button (visible only on permission steps) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAction"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:textColor="@color/white"
        android:textSize="16sp"
        app:backgroundTint="@color/surface_elevated"
        app:cornerRadius="12dp" />

    <View android:layout_width="match_parent" android:layout_height="12dp" />

    <!-- Permission status label -->
    <TextView
        android:id="@+id/tvPermissionStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:textColor="@color/unlocked_color"
        android:textSize="13sp"
        android:visibility="gone" />

    <!-- Spacer bottom -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2" />

    <!-- Progress dots -->
    <LinearLayout
        android:id="@+id/llDots"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:orientation="horizontal">

        <View android:id="@+id/dot0" style="@style/WizardDot" />
        <View android:id="@+id/dot1" style="@style/WizardDot" />
        <View android:id="@+id/dot2" style="@style/WizardDot" />
        <View android:id="@+id/dot3" style="@style/WizardDot" />
        <View android:id="@+id/dot4" style="@style/WizardDot" />
        <View android:id="@+id/dot5" style="@style/WizardDot" />
        <View android:id="@+id/dot6" style="@style/WizardDot" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="24dp" />

    <!-- Next / Done button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="bold"
        app:backgroundTint="@color/primary"
        app:cornerRadius="16dp" />

</LinearLayout>
