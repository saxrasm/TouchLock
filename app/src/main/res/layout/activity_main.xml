<?xml version="1.0" encoding="utf-8"?>
<!--
  activity_main.xml — UI Overhaul
  Greeting at top, large circular status indicator, floating button toggle card.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ── Top bar: Greeting + icons ───────────────────────────────────── -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp">

        <!-- Greeting -->
        <TextView
            android:id="@+id/tvGreeting"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hi there 👋"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Help icon -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHelp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="Help"
            android:text="?"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginEnd="4dp"
            app:backgroundTint="@color/surface_elevated"
            app:cornerRadius="22dp" />

        <!-- Settings icon -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:contentDescription="Settings"
            android:text="⚙"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            app:backgroundTint="@color/surface_elevated"
            app:cornerRadius="22dp" />
    </LinearLayout>

    <!-- ── Centred content ─────────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="28dp"
        android:paddingTop="80dp"
        android:paddingBottom="24dp">

        <!-- Large circular status indicator — 200dp -->
        <FrameLayout
            android:id="@+id/statusIndicator"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center_horizontal">

            <!-- Circle background -->
            <View
                android:id="@+id/statusCircleBg"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/status_circle_bg" />

            <!-- Lock icon emoji -->
            <TextView
                android:id="@+id/tvStatusIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="🔓"
                android:textSize="60sp" />
        </FrameLayout>

        <!-- Status label -->
        <TextView
            android:id="@+id/tvStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/status_unlocked"
            android:textColor="@color/unlocked_color"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Hint text -->
        <TextView
            android:id="@+id/tvHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="@string/hint_lock"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Floating button status text -->
        <TextView
            android:id="@+id/tvFloatingStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Floating button is off"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:visibility="gone" />

        <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

        <!-- ── Bottom card: toggle floating button ─────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardBackgroundColor="@color/surface"
            app:cardCornerRadius="18dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Toggle floating button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggleFloating"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Show Lock Button"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/primary"
                    app:cornerRadius="14dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:gravity="center"
                    android:text="The floating button appears above all apps"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="10dp"
                    android:background="@color/divider" />

                <!-- Unlock hint -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="🔑  Vol Up + Vol Down for 2s to unlock"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</FrameLayout>
