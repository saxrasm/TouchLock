<?xml version="1.0" encoding="utf-8"?>
<!--
  res/layout/widget_lock.xml — Phase 4 (Task 4.2)
  1×1 RemoteViews layout: circular red button with a lock icon and "Lock" label.
  Only views supported by RemoteViews can be used here (no CardView, etc.).
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="8dp">

    <!-- Circular red background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/floating_button_bg"
        android:scaleType="fitXY" />

    <!-- Centred content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/widgetIcon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_lock_float"
            android:contentDescription="Lock icon" />

        <TextView
            android:id="@+id/widgetLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="@string/widget_label"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

</FrameLayout>
