<?xml version="1.0" encoding="utf-8"?>
<!--
  ic_lock_float.xml — vector lock icon for the floating button and widget.
  Sized 24x24dp (standard Material icon grid).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Shackle (arc) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:pathData="M 8,11 L 8,7 A 4,4 0 0 1 16,7 L 16,11" />

    <!-- Lock body -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M 5,11 A 2,2 0 0 1 7,9 L 17,9 A 2,2 0 0 1 19,11 L 19,20 A 2,2 0 0 1 17,22 L 7,22 A 2,2 0 0 1 5,20 Z" />

    <!-- Keyhole -->
    <path
        android:fillColor="#E94560"
        android:pathData="M 12,13 A 1.5,1.5 0 1 0 12,16 A 1.5,1.5 0 0 0 12,13 Z M 11.25,16 L 12.75,16 L 13,19 L 11,19 Z" />
